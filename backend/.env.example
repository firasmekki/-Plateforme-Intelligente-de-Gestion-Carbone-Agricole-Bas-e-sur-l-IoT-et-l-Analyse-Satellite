# ============================================================
# AgroCarbon - Configuration Environnement
# Copier ce fichier en .env et remplir les valeurs
# ⚠️  Ne JAMAIS commiter le fichier .env sur Git
# ============================================================

# Environnement
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:4000

# ────────────────────────────────────────────────────────────
# JWT — Authentification
# ────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_random_64_char_string
JWT_EXPIRES_IN=7d

# ────────────────────────────────────────────────────────────
# PostgreSQL — Base de données principale
# ────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agrocarbon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# ────────────────────────────────────────────────────────────
# InfluxDB — Données capteurs IoT (time-series)
# ────────────────────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_influxdb_token
INFLUX_ORG=agrocarbon
INFLUX_BUCKET=sensors

# ────────────────────────────────────────────────────────────
# Sentinel Hub — Imagerie satellite (optionnel)
# Créer un compte sur https://www.sentinel-hub.com/
# ────────────────────────────────────────────────────────────
SENTINEL_HUB_INSTANCE_ID=your_sentinel_hub_instance_id
SENTINEL_HUB_CLIENT_ID=your_sentinel_hub_client_id
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_hub_client_secret

# ────────────────────────────────────────────────────────────
# Upload de fichiers
# ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────
LOG_LEVEL=info
